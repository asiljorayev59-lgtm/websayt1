<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<title>📜 Trade History Pro - GOLD AI PRO</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
    :root { --gold: #fbbf24; --green: #22c55e; --red: #ef4444; }
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
        background: radial-gradient(circle at 50% 30%, #1e3a5f 0%, #020617 70%);
        color: white;
        font-family: 'Segoe UI', sans-serif;
        min-height: 100vh;
    }
    .header { background:rgba(15,23,42,0.92); backdrop-filter:blur(20px); padding:18px 20px; display:flex; justify-content:space-between; align-items:center; position:sticky; top:0; z-index:100; }
    .main { padding:25px 20px; }
    h1 { text-align:center; font-size:2.5em; color:var(--gold); margin-bottom:20px; }
    
    .stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 40px;
    }
    .stat-card {
        background: #0f172a;
        border-radius: 20px;
        padding: 20px;
        text-align: center;
    }
    
    table {
        width: 100%;
        border-collapse: collapse;
        background: #0f172a;
        border-radius: 20px;
        overflow: hidden;
    }
    th, td {
        padding: 14px 12px;
        text-align: left;
    }
    th { background: #1e2937; }
    tr:nth-child(even) { background: #1a2333; }
</style>
</head>
<body>

<div class="header">
    <div style="font-size:1.8em; font-weight:700; color:var(--gold);">📜 Trade History Pro</div>
    <div id="time" style="color:#94a3b8;"></div>
</div>

<div class="main">
    <h1>Risk Manager & History</h1>
    
    <div class="stats">
        <div class="stat-card">
            <p style="color:#94a3b8;">Win Rate</p>
            <div style="font-size:2.8em; font-weight:800; color:var(--green);">74%</div>
        </div>
        <div class="stat-card">
            <p style="color:#94a3b8;">Joriy Balance</p>
            <div style="font-size:2.2em; font-weight:800;">$12,450</div>
        </div>
        <div class="stat-card">
            <p style="color:#94a3b8;">Risk per Trade</p>
            <div style="font-size:2.2em; font-weight:800; color:var(--gold);">1.0%</div>
        </div>
        <div class="stat-card">
            <p style="color:#94a3b8;">Profit Factor</p>
            <div style="font-size:2.2em; font-weight:800; color:var(--green);">2.35</div>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Sana</th>
                <th>Strategiya</th>
                <th>Signal</th>
                <th>Natija</th>
            </tr>
        </thead>
        <tbody id="historyTable">
            <!-- JS orqali to‘ldiriladi -->
        </tbody>
    </table>
</div>

<script>
function updateTime() {
    const now = new Date();
    document.getElementById("time").textContent = now.toLocaleTimeString('uz-UZ', {hour:'2-digit', minute:'2-digit'});
}
setInterval(updateTime, 10000);
updateTime();

// Fake history
const trades = [
    {date:"Bugun 14:32", strat:"Smart Money", signal:"BUY", result:"WIN"},
    {date:"Bugun 11:15", strat:"Trend", signal:"SELL", result:"LOSS"},
    {date:"Kecha 17:45", strat:"Scalping", signal:"BUY", result:"WIN"},
    {date:"Kecha 09:20", strat:"Smart Money", signal:"BUY", result:"WIN"},
];

let html = "";
trades.forEach(t => {
    html += `<tr>
        <td>${t.date}</td>
        <td>${t.strat}</td>
        <td style="color:${t.signal==='BUY'?'#22c55e':'#ef4444'}">${t.signal}</td>
        <td style="color:${t.result==='WIN'?'#22c55e':'#ef4444'}">${t.result}</td>
    </tr>`;
});
document.getElementById("historyTable").innerHTML = html;
</script>
</body>
</html>
